{
  "format": "tomation-spec",
  "version": 1,
  "meta": {
    "name": "Navigation Wizard",
    "url": "",
    "description": "Tests multi-page navigation through a 3-step wizard flow"
  },
  "pageElements": {
    "Welcome__title": {
      "tag": "h1",
      "where": {
        "id": "page-title"
      }
    },
    "Welcome__stepIndicator": {
      "tag": "div",
      "where": {
        "id": "step-indicator"
      }
    },
    "Info__title": {
      "tag": "h1",
      "where": {
        "id": "page-title"
      }
    },
    "Info__stepIndicator": {
      "tag": "div",
      "where": {
        "id": "step-indicator"
      }
    },
    "Confirm__title": {
      "tag": "h1",
      "where": {
        "id": "page-title"
      }
    },
    "Confirm__successMessage": {
      "tag": "div",
      "where": {
        "id": "success-message"
      }
    },
    "Confirm__stepIndicator": {
      "tag": "div",
      "where": {
        "id": "step-indicator"
      }
    }
  },
  "tasks": {
    "Welcome__verifyPage": {
      "steps": [
        {
          "action": "assertHasText",
          "target": "Welcome__title",
          "value": "Welcome to the Wizard"
        },
        {
          "action": "assertHasText",
          "target": "Welcome__stepIndicator",
          "value": "Step 1 of 3"
        }
      ]
    },
    "Info__verifyPage": {
      "steps": [
        {
          "action": "assertHasText",
          "target": "Info__title",
          "value": "Provide Your Information"
        },
        {
          "action": "assertHasText",
          "target": "Info__stepIndicator",
          "value": "Step 2 of 3"
        }
      ]
    },
    "Confirm__verifyPage": {
      "steps": [
        {
          "action": "assertHasText",
          "target": "Confirm__title",
          "value": "Confirmation"
        },
        {
          "action": "assertHasText",
          "target": "Confirm__successMessage",
          "value": "Wizard completed successfully"
        },
        {
          "action": "assertHasText",
          "target": "Confirm__stepIndicator",
          "value": "Step 3 of 3"
        }
      ]
    }
  },
  "tests": [
    {
      "name": "Full wizard navigation flow",
      "steps": [
        {
          "action": "navigate",
          "url": "index.html"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "task",
          "name": "Welcome__verifyPage"
        },
        {
          "action": "navigate",
          "url": "page2.html"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "task",
          "name": "Info__verifyPage"
        },
        {
          "action": "navigate",
          "url": "page3.html"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "task",
          "name": "Confirm__verifyPage"
        }
      ]
    },
    {
      "name": "Navigate directly to confirmation page",
      "steps": [
        {
          "action": "navigate",
          "url": "page3.html"
        },
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "assertHasText",
          "target": "Confirm__successMessage",
          "value": "Wizard completed successfully"
        },
        {
          "action": "manual",
          "description": "Verify the confirmation page looks correct visually and the success message is styled with a green background"
        }
      ]
    },
    {
      "name": "Navigate back to start from confirmation",
      "steps": [
        {
          "action": "navigate",
          "url": "page3.html"
        },
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "assertHasText",
          "target": "Confirm__title",
          "value": "Confirmation"
        },
        {
          "action": "navigate",
          "url": "index.html"
        },
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "assertHasText",
          "target": "Welcome__title",
          "value": "Welcome to the Wizard"
        },
        {
          "action": "manual",
          "description": "Verify that navigating back to the start resets the wizard state correctly"
        }
      ]
    }
  ]
}
