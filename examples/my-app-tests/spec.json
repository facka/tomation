{
  "format": "tomation-spec",
  "version": 1,
  "meta": {
    "name": "Untitled",
    "url": "",
    "description": ""
  },
  "pageElements": {
    "Login__usernameInput": {
      "tag": "input",
      "where": {
        "id": "username"
      }
    },
    "Login__passwordInput": {
      "tag": "input",
      "where": {
        "id": "password"
      }
    },
    "Login__submitButton": {
      "tag": "button",
      "where": {
        "id": "login-btn"
      }
    },
    "Login__errorMessage": {
      "tag": "div",
      "where": {
        "id": "error-msg"
      }
    }
  },
  "tasks": {
    "Login__fillCredentials": {
      "steps": [
        {
          "action": "type",
          "target": "Login__usernameInput",
          "value": "testuser"
        },
        {
          "action": "typePassword",
          "target": "Login__passwordInput",
          "value": "secret123"
        }
      ]
    },
    "Login__submit": {
      "steps": [
        {
          "action": "click",
          "target": "Login__submitButton"
        }
      ]
    }
  },
  "tests": [
    {
      "name": "Login with valid credentials",
      "steps": [
        {
          "action": "task",
          "name": "Login__fillCredentials"
        },
        {
          "action": "task",
          "name": "Login__submit"
        },
        {
          "action": "assertExists",
          "target": "Login__errorMessage"
        }
      ]
    },
    {
      "name": "Login shows error on empty submit",
      "steps": [
        {
          "action": "click",
          "target": "Login__submitButton"
        },
        {
          "action": "assertHasText",
          "target": "Login__errorMessage",
          "value": "required"
        }
      ]
    }
  ]
}